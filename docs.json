{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "ArcWeather Docs",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "products": [
      {
        "product": "ArcWeather Platform",
        "icon": "layer-group",
        "pages": [
          "platform-getting-started"
        ]
      },
      {
        "product": "ArcWeather API",
        "icon": "code",
        "versions": [
          {
            "version": "1.01",
            "pages": [
              "api-getting-started",
              "authentication",
              "untitled-page",
              "attribution-and-usage-requirements",
              {
                "group": "Radar Services",
                "icon": "radar",
                "openapi": "ArcAPI/radaropenapi.json",
                "pages": [
                  "about-radar-services",
                  "static-radar-service"
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:help@arcweather.cloud"
      },
      {
        "label": "System Status",
        "href": "https://status.arcweather.cloud"
      }
    ],
    "primary": {
      "type": "button",
      "label": "App",
      "href": "https://app.arcweather.cloud"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "appearance": {
    "default": "system"
  },
  "fonts": {
    "family": "Poppins"
  },
  "banner": {
    "dismissible": true,
    "content": "Heads up! These docs are under construction."
  },
  "footer": {
    "socials": {
      "linkedin": "https://www.linkedin.com/company/arcweather",
      "website": "https://arcweather.cloud?ref=docs",
      "instagram": "https://instagram.com/arcweather"
    }
  },
  "interaction": {
    "drilldown": true
  },
  "metadata": {
    "timestamp": true
  }
}
